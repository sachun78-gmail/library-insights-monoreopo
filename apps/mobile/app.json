{
  "expo": {
    "name": "Library Insights",
    "slug": "library-insights",
    "version": "1.0.0",
    "scheme": "libraryinsights",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "work.libraryinsights"
    },
    "android": {
      "package": "work.libraryinsights",
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "libraryinsights"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "@sentry/react-native/expo",
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "도서관 검색을 위해 위치 정보를 사용합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2D6A4F",
          "androidMode": "default",
          "androidCollapsedTitle": "Library Insights"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c66ce7dd-9c43-4e33-8eae-8d88961cea91"
      }
    },
    "owner": "sachun78"
  }
}
