</div>
</div>

<!-- Main Content: Book Detail Page -->
<main class="flex-1 max-w-3xl mx-auto w-full px-0 sm:px-4 py-0 sm:py-6">
  <div class="bg-white dark:bg-charcoal-800 sm:rounded-2xl shadow-lg ring-1 ring-charcoal/10 dark:ring-white/15">

    <!-- 상단 헤더: 뒤로가기 + 찜하기 + 공유 -->
