---
export const prerender = false;

import Auth from '../../components/Auth.astro';
import Analytics from '../../components/Analytics.astro';
import BookDetailModal from '../../components/BookDetailModal.astro';
import Footer from '../../components/Footer.astro';
import LegalModals from '../../components/LegalModals.astro';
import { regions as regionsData } from '../../data/regions.js';
import { fetchLibraryProxy } from '../../lib/library-proxy';

const { isbn } = Astro.params;

if (!isbn) {
  return Astro.redirect('/');
}

// --- 도서 정보 가져오기 (OG 태그용) ---
function getEnvVar(key: string): string | undefined {
  const locals = Astro.locals as any;
  if (locals?.runtime?.env?.[key]) {
    return locals.runtime.env[key];
  }
  return (import.meta.env as any)[key];
}

function stripHtml(str: string | undefined): string {
  if (!str) return '';
  return str
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&nbsp;/g, ' ')
    .replace(/<[^>]*>/g, '');
}

let bookTitle = '';
let bookAuthor = '';
let bookPublisher = '';
let bookDescription = '';
let bookImage = '';
let bookLink = '';
let bookPrice = '';
let bookDiscount = '';
let bookPubdate = '';
let bookIsbn = isbn;
let bookClassNm = '';
let fetchSuccess = false;

// Naver API + Data4Library API 병렬 호출
const clientId = getEnvVar('NAVER_CLIENT_ID');
const clientSecret = getEnvVar('NAVER_CLIENT_SECRET');

// 1) Naver API (책 상세 정보) — book_adv.json + d_isbn으로 정확 검색
const naverPromise = (clientId && clientSecret)
  ? fetch(`https://openapi.naver.com/v1/search/book_adv.json?d_isbn=${encodeURIComponent(isbn.replace(/-/g, ''))}&display=1`, {
      headers: { 'X-Naver-Client-Id': clientId, 'X-Naver-Client-Secret': clientSecret },
    }).then(r => r.ok ? r.json() : null).catch(() => null)
  : Promise.resolve(null);

// 2) Data4Library API (이미지, 분류 등)
const data4libPromise = fetchLibraryProxy(Astro.locals, '/v1/srchDtlList', {
  isbn13: isbn,
  loaninfoYN: 'N',
}).catch(() => null);

const [naverJson, data4libData] = await Promise.all([naverPromise, data4libPromise]);

// Data4Library 결과 파싱
const d4lDetail = data4libData?.response?.detail?.[0]?.book || data4libData?.response?.book;
if (d4lDetail) {
  bookTitle = d4lDetail.bookname || '';
  bookAuthor = d4lDetail.authors || '';
  bookPublisher = d4lDetail.publisher || '';
  bookDescription = d4lDetail.description || '';
  bookImage = d4lDetail.bookImageURL || '';
  bookClassNm = d4lDetail.class_nm || '';
  bookPubdate = d4lDetail.publication_year || '';
  fetchSuccess = true;
}

// Naver 결과로 보완 (Naver에만 있는 정보: 가격, 링크 등)
if (naverJson?.items?.length > 0) {
  const nBook = naverJson.items[0];
  if (!bookTitle) bookTitle = stripHtml(nBook.title);
  if (!bookAuthor) bookAuthor = stripHtml(nBook.author);
  if (!bookPublisher) bookPublisher = nBook.publisher || '';
  if (!bookDescription) bookDescription = stripHtml(nBook.description);
  if (!bookImage) bookImage = nBook.image || '';
  bookLink = nBook.link || '';
  bookPrice = nBook.price || '';
  bookDiscount = nBook.discount || '';
  if (!bookPubdate) bookPubdate = nBook.pubdate || '';
  bookIsbn = nBook.isbn || isbn;
  fetchSuccess = true;
}

const pageTitle = bookTitle ? `${bookTitle} - LibraryInsights` : 'LibraryInsights';
const ogDescription = bookTitle
  ? `${bookAuthor}${bookPublisher ? ` · ${bookPublisher}` : ''}${bookDescription ? ` — ${bookDescription.slice(0, 100)}` : ''}`
  : '한국 공공도서관 대출 데이터를 기반으로 베스트셀러와 추천 도서를 탐색하세요.';
const ogImage = bookImage || 'https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1200&h=630&q=80';
const canonicalUrl = `https://library-insights.work/books/${isbn}`;
---
<html lang="ko" class=""><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script is:inline>
  (function(){
    var t = localStorage.getItem('theme');
    if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  })();
</script>
<title>{pageTitle}</title>
<meta name="description" content={ogDescription}/>
<link rel="canonical" href={canonicalUrl}/>
<meta property="og:site_name" content="LibraryInsights"/>
<meta property="og:type" content="book"/>
<meta property="og:title" content={bookTitle || 'LibraryInsights'}/>
<meta property="og:description" content={ogDescription}/>
<meta property="og:url" content={canonicalUrl}/>
<meta property="og:image" content={ogImage}/>
<meta property="og:locale" content="ko_KR"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content={bookTitle || 'LibraryInsights'}/>
<meta name="twitter:description" content={ogDescription}/>
<meta name="twitter:image" content={ogImage}/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<Analytics />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet"/>
<style>
  body {
    font-family: 'Noto Serif', serif;
  }
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
{fetchSuccess && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Book",
    "name": bookTitle,
    "author": { "@type": "Person", "name": bookAuthor },
    "publisher": { "@type": "Organization", "name": bookPublisher },
    "isbn": bookIsbn,
    "image": bookImage,
    "url": canonicalUrl,
    "description": bookDescription.slice(0, 200),
  })} />
)}
</head>
<body class="bg-background-light dark:bg-background-dark text-charcoal dark:text-white transition-colors duration-300">
<div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
<div class="layout-container flex h-full grow flex-col">
<!-- Top Navigation Bar -->
