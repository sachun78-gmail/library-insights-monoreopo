          <span id="modal-bookmark-text" class="text-xs font-bold">찜하기</span>
        </button>
      </div>
    </div>

    <!-- Book Info -->
    <div class="p-3 sm:p-6 border-b border-charcoal/10 dark:border-white/10">
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-6">
        <img id="modal-book-image" src={bookImage || ''} alt={bookTitle} class="w-24 h-36 sm:w-32 sm:h-48 object-cover rounded-lg flex-shrink-0 mx-auto sm:mx-0" />
