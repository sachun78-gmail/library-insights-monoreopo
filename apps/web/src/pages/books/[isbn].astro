<script define:vars={{ isbn, bookTitle, bookAuthor, bookPublisher, bookImage, bookPubdate, bookClassNm, fetchSuccess }}>
  // 서버에서 받은 도서 정보를 window에 저장하여 클라이언트 스크립트에서 사용
  window.__bookPageData = {
    isbn13: isbn,
    bookname: bookTitle,
    authors: bookAuthor,
    publisher: bookPublisher,
    bookImageURL: bookImage,
    publication_year: bookPubdate ? bookPubdate.slice(0, 4) : '',
    class_nm: bookClassNm,
    fetchSuccess: fetchSuccess,
  };
</script>

<script>
  import { initBookModal, openBookModal as sharedOpenModal } from '../../scripts/book-modal';
  import { initBookmarks, isBookmarked, toggleBookmark, getUserId } from '../../scripts/bookmarks';

  // Initialize bookmarks
  initBookmarks();

  // Initialize book modal (reuses same DOM IDs)
  initBookModal();

  // 서버에서 전달받은 도서 데이터로 모달 로직 초기화
  const bookData = (window as any).__bookPageData;
  if (bookData && bookData.isbn13) {
    // 페이지에 이미 콘텐츠가 렌더링되어 있으므로 모달을 열지 않고
    // 기존 book-modal.ts의 fetch 로직만 실행
    // _currentBook 세팅 및 API 호출을 위해 openBookModal 대신 직접 처리

    // 찜하기 버튼 상태 업데이트
    const bookmarkBtn = document.getElementById('modal-bookmark-btn');
    const bookmarkIcon = document.getElementById('modal-bookmark-icon');
    const bookmarkText = document.getElementById('modal-bookmark-text');

    function updateBookmarkUI() {
      if (!bookmarkBtn || !bookmarkIcon || !bookmarkText) return;
      const filled = isBookmarked(bookData.isbn13);
      bookmarkIcon.style.fontVariationSettings = `'FILL' ${filled ? 1 : 0}, 'wght' 400, 'GRAD' 0, 'opsz' 24`;
      if (filled) {
        bookmarkBtn.classList.add('border-red-400', 'dark:border-red-500', 'text-red-500', 'dark:text-red-400', 'bg-red-50', 'dark:bg-red-900/20');
        bookmarkBtn.classList.remove('border-charcoal/20', 'dark:border-white/20', 'text-charcoal/50', 'dark:text-white/50');
        bookmarkText.textContent = '찜 해제';
      } else {
        bookmarkBtn.classList.remove('border-red-400', 'dark:border-red-500', 'text-red-500', 'dark:text-red-400', 'bg-red-50', 'dark:bg-red-900/20');
        bookmarkBtn.classList.add('border-charcoal/20', 'dark:border-white/20', 'text-charcoal/50', 'dark:text-white/50');
        bookmarkText.textContent = '찜하기';
      }
    }

    updateBookmarkUI();

    bookmarkBtn?.addEventListener('click', async () => {
      if (!getUserId()) {
        document.getElementById('signin-btn')?.click();
        return;
      }
      await toggleBookmark({
        isbn13: bookData.isbn13,
        bookname: bookData.bookname,
        authors: bookData.authors,
        publisher: bookData.publisher,
        publication_year: bookData.publication_year,
        bookImageURL: bookData.bookImageURL,
      });
      updateBookmarkUI();
    });

    // book-modal.ts의 openBookModal을 호출하여 API fetch 로직 재활용
    // 모달은 hidden 상태지만, 같은 DOM ID를 공유하므로 데이터가 페이지에 표시됨
    // 단, 이 페이지에서는 모달의 hidden 제거가 아닌 기존 페이지 요소에 데이터를 채움
    sharedOpenModal(bookData);

    // openBookModal이 모달을 visible로 만들기 때문에 다시 hidden 처리 불필요
    // (이 페이지에서는 book-modal 요소가 없으므로 무시됨)
  }

  // 공유 버튼 로직
  const shareBtn = document.getElementById('page-share-btn');
  const shareToast = document.getElementById('share-toast');

  shareBtn?.addEventListener('click', async () => {
    const shareUrl = window.location.href;
    const shareTitle = document.title;

    if (navigator.share) {
      try {
        await navigator.share({ title: shareTitle, url: shareUrl });
      } catch (e) {
        // 사용자가 공유를 취소한 경우 무시
      }
    } else {
      try {
        await navigator.clipboard.writeText(shareUrl);
        showToast();
      } catch {
        // fallback: 구형 브라우저
        const input = document.createElement('input');
        input.value = shareUrl;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        showToast();
      }
    }
  });

  function showToast() {
    if (!shareToast) return;
    shareToast.classList.remove('opacity-0', 'translate-y-2');
    shareToast.classList.add('opacity-100', 'translate-y-0');
    setTimeout(() => {
      shareToast.classList.add('opacity-0', 'translate-y-2');
      shareToast.classList.remove('opacity-100', 'translate-y-0');
    }, 2000);
  }

  // 테마 토글
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const html = document.documentElement;
    if (html.classList.contains('dark')) {
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  });

  // 모바일 메뉴 토글
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileMenuBtn?.addEventListener('click', () => {
    const expanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
    mobileMenuBtn.setAttribute('aria-expanded', String(!expanded));
    mobileMenu?.classList.toggle('hidden');
  });
</script>
