      <a href="/" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-charcoal/50 dark:text-white/50 hover:text-charcoal dark:hover:text-white hover:bg-charcoal/5 dark:hover:bg-white/10 text-sm font-medium transition-all">
