---
export const prerender = true;

import { getCollection } from 'astro:content';
import Analytics from '../../components/Analytics.astro';
import Footer from '../../components/Footer.astro';
import LegalModals from '../../components/LegalModals.astro';

const posts = (await getCollection('insights')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryColors: Record<string, string> = {
  '분석': 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  '트렌드': 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300',
  '활용팁': 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300',
  '운영이야기': 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
};
---
<html lang="ko" class=""><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script is:inline>
  (function(){
    var t = localStorage.getItem('theme');
    if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  })();
</script>
<title>도서관 인사이트 - LibraryInsights</title>
<meta name="description" content="공공도서관 대출 데이터로 발견한 독서 트렌드, 지역별 분석, 활용 팁까지. LibraryInsights가 직접 분석한 도서관 데이터 이야기를 만나보세요."/>
<link rel="canonical" href="https://library-insights.work/insights"/>
<meta property="og:site_name" content="LibraryInsights"/>
<meta property="og:type" content="website"/>
<meta property="og:title" content="도서관 인사이트 - LibraryInsights"/>
<meta property="og:description" content="공공도서관 대출 데이터로 발견한 독서 트렌드, 지역별 분석, 활용 팁까지. LibraryInsights가 직접 분석한 도서관 데이터 이야기를 만나보세요."/>
<meta property="og:url" content="https://library-insights.work/insights"/>
<meta property="og:image" content="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&w=1200&h=630&q=80"/>
<meta property="og:locale" content="ko_KR"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="도서관 인사이트 - LibraryInsights"/>
<meta name="twitter:description" content="공공도서관 대출 데이터로 발견한 독서 트렌드, 지역별 분석, 활용 팁까지."/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
<Analytics />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; }
</style>
</head>
<body class="bg-white text-charcoal dark:bg-charcoal-900 dark:text-white">

<header class="border-b border-charcoal/10 dark:border-white/10 bg-white/80 dark:bg-[#0f172a]/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-5 sm:px-8 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-charcoal dark:text-white font-bold text-lg">
      <span class="material-symbols-outlined text-primary text-xl leading-none">auto_stories</span>
      LibraryInsights
    </a>
    <nav class="flex items-center gap-4 text-sm text-charcoal/70 dark:text-white/70">
      <a href="/bestsellers" class="hover:text-primary transition-colors">베스트셀러</a>
      <a href="/insights" class="text-primary font-medium">인사이트</a>
      <a href="/contact" class="hover:text-primary transition-colors">문의하기</a>
    </nav>
  </div>
</header>

<main class="mx-auto max-w-5xl px-5 py-12 sm:px-8">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-charcoal dark:text-white mb-3">도서관 인사이트</h1>
    <p class="text-charcoal/60 dark:text-white/50 text-base">전국 공공도서관 대출 데이터로 발견한 독서 트렌드와 분석, 활용 팁을 전합니다.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {posts.map((post) => (
      <a href={`/insights/${post.slug}`} class="group block rounded-2xl border border-charcoal/10 dark:border-white/10 overflow-hidden hover:border-primary/50 transition-colors">
        {post.data.thumbnail && (
          <div class="aspect-video overflow-hidden bg-charcoal/5 dark:bg-white/5">
            <img
              src={post.data.thumbnail}
              alt={post.data.thumbnailAlt ?? post.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
        )}
        <div class="p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${categoryColors[post.data.category] ?? ''}`}>
              {post.data.category}
            </span>
            <time class="text-xs text-charcoal/50 dark:text-white/40" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <h2 class="font-bold text-charcoal dark:text-white text-base leading-snug mb-2 group-hover:text-primary transition-colors line-clamp-2">
            {post.data.title}
          </h2>
          <p class="text-sm text-charcoal/60 dark:text-white/50 leading-6 line-clamp-3">
            {post.data.description}
          </p>
        </div>
      </a>
    ))}
  </div>
</main>

<Footer />
<LegalModals />

<script>
  import '../../scripts/theme';
</script>
</body></html>
