---
import Analytics from '../components/Analytics.astro';
import Footer from '../components/Footer.astro';
import LegalModals from '../components/LegalModals.astro';
---
<html lang="ko" class=""><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script is:inline>
  (function(){
    var t = localStorage.getItem('theme');
    if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  })();
</script>
<title>서비스 소개 - LibraryInsights</title>
<meta name="description" content="LibraryInsights는 전국 공공도서관 대출 데이터를 분석해 독자에게 가장 신뢰할 수 있는 도서 추천을 제공하는 서비스입니다."/>
<link rel="canonical" href="https://library-insights.work/about"/>
<meta property="og:site_name" content="LibraryInsights"/>
<meta property="og:type" content="website"/>
<meta property="og:title" content="서비스 소개 - LibraryInsights"/>
<meta property="og:description" content="LibraryInsights는 전국 공공도서관 대출 데이터를 분석해 독자에게 가장 신뢰할 수 있는 도서 추천을 제공하는 서비스입니다."/>
<meta property="og:url" content="https://library-insights.work/about"/>
<meta property="og:image" content="https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1200&h=630&q=80"/>
<meta property="og:locale" content="ko_KR"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="서비스 소개 - LibraryInsights"/>
<meta name="twitter:description" content="LibraryInsights는 전국 공공도서관 대출 데이터를 분석해 독자에게 가장 신뢰할 수 있는 도서 추천을 제공하는 서비스입니다."/>
<meta name="twitter:image" content="https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1200&h=630&q=80"/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<Analytics />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; }
</style>
</head>
<body class="bg-white text-charcoal dark:bg-charcoal-900 dark:text-white">

<!-- 상단 네비게이션 -->
<header class="border-b border-charcoal/10 dark:border-white/10 bg-white/80 dark:bg-[#0f172a]/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-charcoal dark:text-white font-bold text-lg">
      <span class="material-symbols-outlined text-primary text-xl leading-none">auto_stories</span>
      LibraryInsights
    </a>
    <nav class="flex items-center gap-4 text-sm text-charcoal/70 dark:text-white/70">
      <a href="/bestsellers" class="hover:text-primary transition-colors">베스트셀러</a>
      <a href="/insights" class="hover:text-primary transition-colors">도서관 인사이트</a>
      <a href="/contact" class="hover:text-primary transition-colors">문의하기</a>
    </nav>
  </div>
</header>

<main class="mx-auto max-w-3xl px-5 py-12 sm:px-8">
  <a href="/" class="mb-8 inline-flex items-center gap-1 text-sm text-charcoal/60 hover:text-charcoal dark:text-white/60 dark:hover:text-white">
    <span class="material-symbols-outlined text-base">arrow_back</span>
    홈으로 돌아가기
  </a>

  <h1 class="mb-3 text-3xl font-bold text-charcoal dark:text-white">LibraryInsights 소개</h1>
  <p class="mb-12 text-charcoal/60 dark:text-white/50 text-base">도서관 데이터가 만드는 더 나은 독서 경험</p>

  <div class="space-y-10 text-sm leading-7 text-charcoal/80 dark:text-white/80">

    <!-- 서비스 소개 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">서비스 소개</h2>
      <p>
        LibraryInsights는 <strong>전국 공공도서관 대출 데이터</strong>를 기반으로 독자에게 가장 신뢰할 수 있는 도서 정보를 제공합니다.
        베스트셀러 순위는 상업적 판매량이 아닌, 실제로 사람들이 빌려 읽은 책 데이터로 산출됩니다.
        광고나 출판사 협찬 없이 순수한 도서관 대출 기록만으로 집계되기 때문에,
        더욱 솔직하고 다양한 독서 트렌드를 확인할 수 있습니다.
      </p>
    </section>

    <!-- 왜 도서관 데이터인가 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">왜 도서관 데이터인가요?</h2>
      <p class="mb-4">
        서점 베스트셀러는 마케팅 예산과 초기 구매 집중 현상의 영향을 받습니다.
        반면 도서관 대출 순위는 독자가 실제로 읽고 싶어 기다리고 빌려간 책을 반영합니다.
        LibraryInsights는 한국문화정보원의 <strong>공공도서관 정보나루(Data4Library) API</strong>를 활용해
        전국 수천 개 공공도서관의 대출 데이터를 집계합니다.
      </p>
      <ul class="list-disc list-inside space-y-2 pl-2">
        <li>지역별 · 연령별 · 성별 독서 트렌드 비교</li>
        <li>급상승 도서 실시간 추적</li>
        <li>내 주변 도서관 소장 여부 확인</li>
        <li>AI 기반 맞춤 도서 추천</li>
      </ul>
    </section>

    <!-- 주요 기능 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">주요 기능</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <div class="mb-2 font-semibold text-charcoal dark:text-white">📚 공공도서관 베스트셀러</div>
          <p class="text-xs leading-6">전국 공공도서관 실제 대출 건수 기준 인기 도서를 지역·연령·성별·기간별로 필터링하여 확인합니다.</p>
        </div>
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <div class="mb-2 font-semibold text-charcoal dark:text-white">🔍 도서 검색 및 상세 정보</div>
          <p class="text-xs leading-6">도서 제목, 저자, ISBN으로 검색하고 소장 도서관, 가격, 책 소개 등 상세 정보를 한눈에 확인합니다.</p>
        </div>
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <div class="mb-2 font-semibold text-charcoal dark:text-white">🤖 AI 맞춤 추천</div>
          <p class="text-xs leading-6">내 독서 취향과 독서 이력을 분석해 개인화된 도서를 추천합니다. 월별 추천 도서도 제공합니다.</p>
        </div>
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <div class="mb-2 font-semibold text-charcoal dark:text-white">📖 내 서재</div>
          <p class="text-xs leading-6">읽고 싶은 책, 읽는 중, 다 읽은 책을 관리하고 독서 통계를 확인합니다.</p>
        </div>
      </div>
    </section>

    <!-- 데이터 출처 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">데이터 출처</h2>
      <p>
        LibraryInsights는 다음 공개 API를 활용합니다.
      </p>
      <ul class="mt-3 list-disc list-inside space-y-2 pl-2">
        <li><strong>공공도서관 정보나루 (Data4Library)</strong> — 한국문화정보원이 제공하는 전국 공공도서관 대출 통계 및 장서 정보</li>
        <li><strong>네이버 도서 API</strong> — 도서 상세 정보, 표지 이미지, 가격 정보</li>
      </ul>
      <p class="mt-4 text-xs text-charcoal/50 dark:text-white/40">
        본 서비스는 공공데이터를 가공·분석하여 제공하며, 원 데이터의 저작권은 각 제공기관에 있습니다.
      </p>
    </section>

    <!-- 서비스를 만든 이유 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">왜 LibraryInsights를 만들었나요?</h2>
      <p class="mb-4">
        서점 베스트셀러 목록을 보면서 "정말 이게 사람들이 가장 많이 읽는 책일까?"라는 의문에서 출발했습니다.
        서점 순위는 마케팅 예산과 출판사의 초도 물량 전략에 영향을 받습니다.
        반면 도서관 대출 순위는 독자가 직접 기다리고 빌려간 책의 기록입니다.
        광고 없이, 협찬 없이, 오직 독자의 선택만으로 만들어진 순위를 보여주고 싶었습니다.
      </p>
      <p>
        공공데이터포털에서 발견한 정보나루 API에는 전국 수천 개 공공도서관의 대출 기록이 담겨 있었습니다.
        이 데이터를 누구나 쉽게 탐색할 수 있는 서비스로 만들면 독자들에게 분명히 가치 있을 것이라 판단했습니다.
      </p>
    </section>

    <!-- 운영 철학 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">운영 철학</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <div class="mb-2 font-semibold text-charcoal dark:text-white">📊 데이터 기반</div>
          <p class="text-xs leading-6">추측이 아닌 실제 대출 데이터를 기반으로 순위를 산출합니다. 모든 통계는 공공 API에서 직접 집계됩니다.</p>
        </div>
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <div class="mb-2 font-semibold text-charcoal dark:text-white">🔓 광고 없는 추천</div>
          <p class="text-xs leading-6">출판사 협찬이나 유료 광고로 순위가 올라가는 일은 없습니다. 데이터가 말하는 그대로를 보여줍니다.</p>
        </div>
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <div class="mb-2 font-semibold text-charcoal dark:text-white">🌍 공공 가치</div>
          <p class="text-xs leading-6">공공도서관과 공공데이터의 가치를 더 많은 사람에게 알리는 것이 이 서비스의 궁극적인 목표입니다.</p>
        </div>
      </div>
    </section>

    <!-- 사용법 가이드 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">서비스 사용법</h2>
      <ol class="list-decimal list-inside space-y-3 pl-2">
        <li>
          <strong>베스트셀러 탐색</strong> — 지역·연령·성별·기간 필터를 조합해 나에게 맞는 도서 순위를 확인하세요.
          전국 통합 순위뿐 아니라 내 지역에서 인기 있는 책을 따로 볼 수 있습니다.
        </li>
        <li>
          <strong>도서 검색</strong> — 제목, 저자, ISBN으로 책을 검색하면 주변 도서관 소장 여부와 대출 가능 여부를 바로 확인할 수 있습니다.
        </li>
        <li>
          <strong>로그인 후 맞춤 추천</strong> — Google 또는 Kakao 계정으로 로그인하면 AI 맞춤 추천과 내 서재 기능을 이용할 수 있습니다.
        </li>
        <li>
          <strong>인사이트 읽기</strong> — 도서관 데이터를 기반으로 직접 분석한 독서 트렌드 글을 <a href="/insights" class="text-primary underline hover:no-underline">인사이트 페이지</a>에서 확인하세요.
        </li>
      </ol>
    </section>

    <!-- 향후 로드맵 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">앞으로의 계획</h2>
      <p class="mb-4">LibraryInsights는 개인이 운영하는 서비스로, 천천히 그러나 꾸준히 기능을 추가하고 있습니다. 현재 준비 중인 기능은 다음과 같습니다.</p>
      <ul class="list-disc list-inside space-y-2 pl-2">
        <li>도서관별 상세 페이지 — 내 주변 도서관의 특성과 인기 도서 목록</li>
        <li>독서 모임 기능 — 같은 책을 읽는 사람들과 연결</li>
        <li>연간 독서 리포트 — 한 해 동안의 독서 통계와 인사이트</li>
        <li>사서 추천 코너 — 각 도서관 사서의 직접 추천 도서 큐레이션</li>
      </ul>
      <p class="mt-4 text-xs text-charcoal/50 dark:text-white/40">
        원하는 기능이 있다면 <a href="/contact" class="text-primary underline hover:no-underline">문의하기</a>를 통해 제안해주세요. 모든 의견을 읽고 반영하려고 노력합니다.
      </p>
    </section>

    <!-- 문의 -->
    <section>
      <h2 class="mb-3 text-xl font-bold text-charcoal dark:text-white">문의 및 의견</h2>
      <p>
        서비스 이용 중 불편한 점, 개선 요청, 오류 신고는 언제든지 환영합니다.
        <a href="/contact" class="text-primary underline hover:no-underline">문의하기 페이지</a>에서 연락해 주세요.
        개인정보, 저작권, 법적 문의는
        <a href="mailto:sachun78@gmail.com" class="text-primary underline hover:no-underline">sachun78@gmail.com</a>으로 직접 연락해 주세요.
      </p>
    </section>

  </div>
</main>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "LibraryInsights",
  "url": "https://library-insights.work",
  "description": "전국 공공도서관 대출 데이터를 분석해 독자에게 신뢰할 수 있는 도서 추천을 제공하는 서비스",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "sachun78@gmail.com",
    "contactType": "customer support",
    "availableLanguage": "Korean"
  }
})} />

<Footer />
<LegalModals />

<script>
  import '../scripts/theme';
</script>
</body></html>
