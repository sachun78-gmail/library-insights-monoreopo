      <div id="mobile-auth-logged-out" class="mt-4 flex items-center justify-between">
        <button id="mobile-signup-btn" class="px-4 py-2 rounded-full bg-charcoal text-white text-xs font-bold">회원가입</button>
        <button id="mobile-signin-btn" class="text-xs font-bold text-charcoal dark:text-white">로그인 &gt;</button>
      </div>
      <div id="mobile-auth-logged-in" class="hidden mt-4">
        <div class="flex items-center gap-3">
