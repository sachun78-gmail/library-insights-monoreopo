---
import Analytics from '../components/Analytics.astro';
import Footer from '../components/Footer.astro';
import LegalModals from '../components/LegalModals.astro';
---
<html lang="ko" class=""><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script is:inline>
  (function(){
    var t = localStorage.getItem('theme');
    if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  })();
</script>
<title>문의하기 - LibraryInsights</title>
<meta name="description" content="LibraryInsights 서비스 이용 문의, 오류 신고, 개선 제안을 보내주세요. 빠른 시일 내 답변 드립니다."/>
<link rel="canonical" href="https://library-insights.work/contact"/>
<meta property="og:site_name" content="LibraryInsights"/>
<meta property="og:type" content="website"/>
<meta property="og:title" content="문의하기 - LibraryInsights"/>
<meta property="og:description" content="LibraryInsights 서비스 이용 문의, 오류 신고, 개선 제안을 보내주세요."/>
<meta property="og:url" content="https://library-insights.work/contact"/>
<meta property="og:image" content="https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1200&h=630&q=80"/>
<meta property="og:locale" content="ko_KR"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="문의하기 - LibraryInsights"/>
<meta name="twitter:description" content="LibraryInsights 서비스 이용 문의, 오류 신고, 개선 제안을 보내주세요. 빠른 시일 내 답변 드립니다."/>
<meta name="twitter:image" content="https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1200&h=630&q=80"/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<Analytics />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; }
</style>
</head>
<body class="bg-white text-charcoal dark:bg-charcoal-900 dark:text-white">

<!-- 상단 네비게이션 -->
<header class="border-b border-charcoal/10 dark:border-white/10 bg-white/80 dark:bg-[#0f172a]/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-charcoal dark:text-white font-bold text-lg">
      <span class="material-symbols-outlined text-primary text-xl leading-none">auto_stories</span>
      LibraryInsights
    </a>
    <nav class="flex items-center gap-4 text-sm text-charcoal/70 dark:text-white/70">
      <a href="/about" class="hover:text-primary transition-colors">서비스 소개</a>
      <a href="/bestsellers" class="hover:text-primary transition-colors">베스트셀러</a>
      <a href="/insights" class="hover:text-primary transition-colors">도서관 인사이트</a>
    </nav>
  </div>
</header>

<main class="mx-auto max-w-3xl px-5 py-12 sm:px-8">
  <a href="/" class="mb-8 inline-flex items-center gap-1 text-sm text-charcoal/60 hover:text-charcoal dark:text-white/60 dark:hover:text-white">
    <span class="material-symbols-outlined text-base">arrow_back</span>
    홈으로 돌아가기
  </a>

  <h1 class="mb-3 text-3xl font-bold text-charcoal dark:text-white">문의하기</h1>
  <p class="mb-10 text-charcoal/60 dark:text-white/50 text-base">서비스 이용 중 궁금한 점이나 불편한 점을 알려주세요.</p>

  <div class="space-y-8 text-sm leading-7 text-charcoal/80 dark:text-white/80">

    <!-- 문의 유형 안내 -->
    <section>
      <h2 class="mb-4 text-lg font-bold text-charcoal dark:text-white">어떤 문의든 환영합니다</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-4 text-center">
          <div class="text-2xl mb-2">🐛</div>
          <div class="font-semibold text-charcoal dark:text-white mb-1">오류 신고</div>
          <p class="text-xs text-charcoal/60 dark:text-white/50">서비스 이용 중 발생한 버그나 오류를 알려주세요.</p>
        </div>
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-4 text-center">
          <div class="text-2xl mb-2">💡</div>
          <div class="font-semibold text-charcoal dark:text-white mb-1">기능 제안</div>
          <p class="text-xs text-charcoal/60 dark:text-white/50">추가되면 좋겠다고 생각하는 기능을 제안해 주세요.</p>
        </div>
        <div class="rounded-xl border border-charcoal/10 dark:border-white/10 p-4 text-center">
          <div class="text-2xl mb-2">❓</div>
          <div class="font-semibold text-charcoal dark:text-white mb-1">일반 문의</div>
          <p class="text-xs text-charcoal/60 dark:text-white/50">서비스 이용 방법이나 기타 궁금한 사항을 질문해 주세요.</p>
        </div>
      </div>
    </section>

    <!-- 문의 방법 -->
    <section>
      <h2 class="mb-4 text-lg font-bold text-charcoal dark:text-white">문의 방법</h2>
      <div class="rounded-xl border border-charcoal/10 dark:border-white/10 divide-y divide-charcoal/10 dark:divide-white/10">
        <div class="flex items-start gap-4 p-5">
          <span class="material-symbols-outlined text-primary mt-0.5">mail</span>
          <div>
            <div class="font-semibold text-charcoal dark:text-white mb-1">이메일 문의</div>
            <p class="text-charcoal/70 dark:text-white/60">
              이메일로 문의 내용을 보내주시면 빠른 시일 내 답변 드립니다.<br/>
              <a href="mailto:sachun78@gmail.com" class="text-primary underline hover:no-underline">sachun78@gmail.com</a><br/>
              <strong>개인정보 관련 요청</strong>(열람·정정·삭제)도 동일한 채널을 이용해 주세요.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-5">
          <span class="material-symbols-outlined text-primary mt-0.5">schedule</span>
          <div>
            <div class="font-semibold text-charcoal dark:text-white mb-1">응답 시간</div>
            <p class="text-charcoal/70 dark:text-white/60">
              문의 접수 후 영업일 기준 <strong>2~3일 이내</strong> 답변을 드립니다.<br/>
              오류 신고의 경우 우선적으로 처리합니다.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-5">
          <span class="material-symbols-outlined text-primary mt-0.5">info</span>
          <div>
            <div class="font-semibold text-charcoal dark:text-white mb-1">문의 시 포함할 내용</div>
            <ul class="text-charcoal/70 dark:text-white/60 list-disc list-inside space-y-1 mt-1">
              <li>문의 유형 (오류 신고 / 기능 제안 / 일반 문의)</li>
              <li>오류 신고의 경우: 발생 화면, 사용 기기, 재현 방법</li>
              <li>답변 받을 이메일 주소</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <h2 class="mb-4 text-lg font-bold text-charcoal dark:text-white">자주 묻는 질문</h2>
      <div class="space-y-3">
        <details class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <summary class="font-semibold text-charcoal dark:text-white cursor-pointer">도서관 소장 정보가 실제와 다릅니다.</summary>
          <p class="mt-3 text-charcoal/70 dark:text-white/60">
            도서관 소장 정보는 공공도서관 정보나루 API에서 실시간으로 가져옵니다.
            대출 중이거나 반납 처리 지연이 있을 경우 실제와 차이가 생길 수 있습니다.
            정확한 소장 여부는 해당 도서관에 직접 문의해 주세요.
          </p>
        </details>
        <details class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <summary class="font-semibold text-charcoal dark:text-white cursor-pointer">회원 탈퇴는 어떻게 하나요?</summary>
          <p class="mt-3 text-charcoal/70 dark:text-white/60">
            마이페이지 → 계정 설정에서 회원 탈퇴를 진행할 수 있습니다.
            탈퇴 시 모든 개인정보 및 서재 데이터가 즉시 삭제됩니다.
          </p>
        </details>
        <details class="rounded-xl border border-charcoal/10 dark:border-white/10 p-5">
          <summary class="font-semibold text-charcoal dark:text-white cursor-pointer">베스트셀러 데이터는 얼마나 자주 업데이트되나요?</summary>
          <p class="mt-3 text-charcoal/70 dark:text-white/60">
            공공도서관 정보나루 API 기준으로 매일 업데이트됩니다.
            단, 데이터 제공 기관의 업데이트 일정에 따라 1~2일 지연될 수 있습니다.
          </p>
        </details>
      </div>
    </section>

  </div>
</main>

<Footer />
<LegalModals />

<script>
  import '../scripts/theme';
</script>
</body></html>
